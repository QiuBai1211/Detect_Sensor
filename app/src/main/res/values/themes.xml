<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.SensorDetector" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/primary</item>
    </style>
    
    <!-- 深色主题 -->
    <style name="Theme.SensorDetector.Dark" parent="Theme.SensorDetector">
        <item name="android:forceDarkAllowed">true</item>
    </style>
    
    <!-- 全屏主题 -->
    <style name="Theme.SensorDetector.Fullscreen" parent="Theme.SensorDetector">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>
    
    <!-- 文本样式 -->
    <style name="TextAppearance.SensorDetector.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SensorDetector.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SensorDetector.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.SensorDetector.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_tertiary</item>
    </style>
    
    <!-- 按钮样式 -->
    <style name="Widget.SensorDetector.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_normal</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <style name="Widget.SensorDetector.Button.Accent" parent="Widget.SensorDetector.Button">
        <item name="backgroundTint">@color/button_accent</item>
    </style>
    
    <!-- 卡片样式 -->
    <style name="Widget.SensorDetector.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>
    
    <!-- 进度条样式 -->
    <style name="Widget.SensorDetector.ProgressBar" parent="Widget.MaterialComponents.ProgressIndicator">
        <item name="indicatorColor">@color/accent_primary</item>
        <item name="trackColor">@color/background_container</item>
    </style>
</resources>
