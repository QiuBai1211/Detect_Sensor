<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                style="@style/TextAppearance.SensorDetector.Headline"/>

            <TextView
                android:id="@+id/tv_sensor_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检测中..."
                android:textSize="18sp"
                android:textColor="#4ECDC4"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="状态：初始化..."
                android:textSize="14sp"
                android:textColor="#FFEAA7"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- 传感器列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 检测到的传感器"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#2D2D2D"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_sensor_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </ScrollView>
        </LinearLayout>

        <!-- 主要传感器数据显示 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- 加速度计 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈 加速度计"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B6B"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_accelerometer_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- 陀螺仪和磁力计 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:elevation="3dp">

                <!-- 陀螺仪 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌀 陀螺仪"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4ECDC4"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_gyroscope_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp"/>

                <!-- 磁力计 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧭 磁力计"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#45B7D1"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_magnetic_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 实时传感器值 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 实时数据流"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="#2D2D2D"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_sensor_values"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </ScrollView>
        </LinearLayout>

        <!-- 功能说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="#2A2A2A"
            android:text="🎯 功能特性：\n• 检测所有可用传感器\n• 实时数据显示\n• 加速度计角度计算\n• 摇晃检测\n• 接近/光线传感器检测\n• 美观的UI界面"
            android:textColor="#888888"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
</ScrollView>
